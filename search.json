---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url | relative_url }}",
    "date": "{{ post.date | date: "%b %-d, %Y" }}",
    "summary": {{ post.summary | default: post.excerpt | strip_html | truncatewords: 40 | jsonify }},
    "authors": {{ post.authors | map: "name" | join: ", " | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
